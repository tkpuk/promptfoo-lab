# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
